# Kite Connect — https://developers.kite.trade

KITE_API_KEY=hc9e625185ns48gusfdvd

KITE_API_SECRET=



# Must match exactly what you registered at developers.kite.trade

KITE_REDIRECT_URL=http://127.0.0.1:8000/auth/kite/callback



# Backend

PORT=8000



# Frontend (for CORS / post-login redirect). On cloud, set to your public URL.

FRONTEND_URL=http://127.0.0.1:5173

# Vercel (set in Project → Environment Variables; VERCEL=1 is automatic):
# FRONTEND_URL=https://your-app.vercel.app
# KITE_REDIRECT_URL=https://your-app.vercel.app/auth/kite/callback
# SESSION_SECRET=<32+ random chars — required on Vercel>
# COOKIE_SECURE=true
# KITE_AUDIT_LOG=0

# Production: backend serves frontend/dist on one port (see docs/DEPLOY-24-7.md)

# NODE_ENV=production

# SERVE_FRONTEND=true

# HOST=0.0.0.0



# Session encryption (32+ chars). If unset, a local secret is generated under backend/data/.session-secret

SESSION_SECRET=



# Production: set NODE_ENV=production and SESSION_SECRET. Debug routes off unless KITE_DEBUG_ROUTES=1

# KITE_DEBUG_ROUTES=0

# COOKIE_SECURE=true



# Admin feedback dashboard — http://127.0.0.1:5173/admin (Bearer auth; keep secret)

ANALYTICS_ADMIN_KEY=change-me-to-a-long-random-secret

